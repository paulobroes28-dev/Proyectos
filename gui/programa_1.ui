  <property name="styleSheet">
   <string notr="true">/* ===============================
   FUENTE GLOBAL
   =============================== */
* {
    font-family: &quot;Segoe UI&quot;, &quot;Helvetica Neue&quot;, Arial, sans-serif;
    font-size: 18px;
    color: #222222;   /* MÁS OSCURO */
}

/* ===============================
   QDialog
   =============================== */
QDialog {
    background-color: #f2f4f8;  /* gris claro azulado */
    border: 1px solid #bfc7d5;
    border-radius: 10px;
}

/* ===============================
   QLabel
   =============================== */
QLabel {
    color: #1f2933;
    background: transparent;
    font-weight: 500;
}

/* Títulos como &quot;Resultados&quot; */
QLabel#labelResultados {
    font-size: 22px;
    font-weight: 600;
    color: #0f172a;
}

/* ===============================
   QLineEdit
   =============================== */
QLineEdit {
    background-color: #eef1f6;   /* NO blanco puro */
    border: 2px solid #9aa4b2;   /* BORDE MÁS FUERTE */
    border-radius: 6px;
    padding: 6px 10px;

    color: #0f172a;              /* TEXTO BIEN OSCURO */
    font-weight: 600;            /* números más gruesos */
    selection-background-color: #4a90e2;
}

/* QLineEdit enfocado */
QLineEdit:focus {
    background-color: #ffffff;
    border: 2px solid #2563eb;
}

/* QLineEdit deshabilitado (resultados) */
QLineEdit:disabled {
    background-color: #e5e7eb;
    border: 2px solid #9ca3af;
    color: #111827;
}

/* ===============================
   QPushButton
   =============================== */
QPushButton {
    background-color: #d1d5db;
    border: 2px solid #9ca3af;
    border-radius: 8px;
    padding: 8px 18px;

    color: #111827;
    font-weight: 600;
}

/* Hover */
QPushButton:hover {
    background-color: #c7d2fe;
    border: 2px solid #6366f1;
}

/* Presionado */
QPushButton:pressed {
    background-color: #4f46e5;
    border: 2px solid #312e81;
    color: #ffffff;
}

/* Deshabilitado */
QPushButton:disabled {
    background-color: #e5e7eb;
    border: 2px solid #d1d5db;
    color: #9ca3af;
}
</string>
