  <property name="styleSheet">
   <string notr="true">/* ===============================
   FUENTE GLOBAL
   =============================== */
* {
    font-family: &quot;Segoe UI&quot;, &quot;Helvetica Neue&quot;, Arial, sans-serif;
    font-size: 18px;
    color: #1e293b;
}

/* ===============================
   QDialog
   =============================== */
QDialog {
    background-color: #f0f9ff;
    border: 2px solid #38bdf8;
    border-radius: 12px;
}

/* ===============================
   QLabel
   =============================== */
QLabel {
    color: #0f172a;
    background: transparent;
    font-weight: 500;
}

/* Títulos */
QLabel#labelResultados {
    font-size: 24px;
    font-weight: 700;
    color: #0284c7;
}

/* ===============================
   QLineEdit
   =============================== */
QLineEdit {
    background-color: #e0f2fe;
    border: 2px solid #38bdf8;
    border-radius: 8px;
    padding: 6px 10px;

    color: #0c4a6e;
    font-weight: 600;
    selection-background-color: #7dd3fc;
}

/* Focus */
QLineEdit:focus {
    background-color: #ffffff;
    border: 2px solid #0ea5e9;
}

/* Disabled */
QLineEdit:disabled {
    background-color: #e0f2fe;
    border: 2px solid #bae6fd;
    color: #64748b;
}

/* ===============================
   QPushButton
   =============================== */
QPushButton {
    background-color: #38bdf8;
    border: 2px solid #0ea5e9;
    border-radius: 10px;
    padding: 8px 18px;

    color: #ffffff;
    font-weight: 700;
}

/* Hover */
QPushButton:hover {
    background-color: #7dd3fc;
    border: 2px solid #0284c7;
}

/* Pressed */
QPushButton:pressed {
    background-color: #0284c7;
    border: 2px solid #075985;
    color: #ffffff;
}

/* Disabled */
QPushButton:disabled {
    background-color: #bae6fd;
    border: 2px solid #e0f2fe;
    color: #94a3b8;
}</string>
