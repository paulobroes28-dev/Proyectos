}

QLineEdit {
    background-color: #ffffff;
    border: 2px solid #d4af37; /* Dorado clásico */
    border-radius: 6px;
    padding: 6px;
    font-size: 12pt;
    color: #8a6d1a;
}

QLineEdit:focus {
    border: 2px solid #b8962e; /* Dorado más profundo */
    background-color: #fff3cd; /* Amarillo suave */
}

QPushButton {
    background-color: #d4af37; /* Dorado principal */
    color: #ffffff;
    border: none;
    border-radius: 8px;
    padding: 10px 18px;
    font-size: 12pt;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #c19a2b; /* Dorado más intenso */
}

QPushButton:pressed {
    background-color: #a67c00; /* Dorado oscuro */
}</string>
