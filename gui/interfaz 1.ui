  <property name="styleSheet">
   <string notr="true">/* Fuente global */
* {
    font-family: &quot;Segoe UI&quot;, &quot;Helvetica Neue&quot;, Arial, sans-serif;
    font-size: 18px;
    color: #333333;
}

/* QDialog */
QDialog {
    background-color: #f9f9f9; /* color base 60% */
    border: 1px solid #dcdcdc;
    border-radius: 8px;
}

/* QLabel */
QLabel {
    color: #333333;
    background: transparent;
}

/* QLineEdit */
QLineEdit {
    background-color: #ffffff;
    border: 1px solid #cccccc; /* color secundario 30% */
    border-radius: 6px;
    padding: 6px;
}
QLineEdit:focus {
    border: 1px solid #4a90e2; /* acento 10% */
    background-color: #fdfdfd;
}

/* QPushButton */
QPushButton {
    background-color: #e6e6e6; /* secundario 30% */
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    color: #333333;
}
QPushButton:hover {
    background-color: #dcdcdc;
}
QPushButton:pressed {
    background-color: #4a90e2; /* acento 10% */
    color: #ffffff;
}
QPushButton:disabled {
    background-color: #f0f0f0;
    color: #999999;
}</string>
